{
  "title": "Consumer Metrics",
  "uid": "consumer-metrics-v1",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Events per second",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "rate(events_processed_total[1m])",
          "legendFormat": "events/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 2,
      "title": "Anomaly rate %",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "sum(rate(anomalies_detected_total[1m])) / rate(events_processed_total[1m]) * 100",
          "legendFormat": "anomaly rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 3,
      "title": "Anomalies by type",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "rate(anomalies_detected_total{anomaly_type=~\".+\"}[1m])",
          "legendFormat": "{{anomaly_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 4,
      "title": "Processing latency p95",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(processing_latency_seconds_bucket[1m]))",
          "legendFormat": "p95 latency",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 5,
      "title": "Errors + Drift",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "rate(processing_errors_total[1m])",
          "legendFormat": "errors/sec",
          "refId": "A"
        },
        {
          "expr": "rate(drift_events_total[1m])",
          "legendFormat": "drift/sec",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    }
  ]
}